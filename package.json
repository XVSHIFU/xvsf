{
  "name": "xvsf-blog-tooling",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic validation and content tooling for the xvsf Hugo blog",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "cms:check": "node scripts/cms-config.mjs",
    "frontmatter:check": "node scripts/frontmatter.mjs --check",
    "frontmatter:write": "node scripts/frontmatter.mjs --write",
    "quality:check": "node scripts/content-quality.mjs --check",
    "quality:report": "node scripts/content-quality.mjs --report",
    "images:audit": "node scripts/content-quality.mjs --images",
    "schedule:check": "node scripts/content-quality.mjs --schedule",
    "schedule:test": "node scripts/test-scheduling.mjs",
    "taxonomies:seed": "node scripts/seed-taxonomies.mjs",
    "validate:html": "html-validate \".ci-site/xvsf/**/*.html\""
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "html-validate": "11.5.6",
    "remark-parse": "11.0.0",
    "sharp": "0.35.3",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "yaml": "2.9.0"
  }
}
