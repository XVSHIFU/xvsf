{
  "name": "xvsf-blog-tooling",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic validation and content tooling for the xvsf Hugo blog",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "cms:check": "node scripts/cms-config.mjs",
    "frontmatter:check": "node scripts/frontmatter.mjs --check",
    "frontmatter:write": "node scripts/frontmatter.mjs --write",
    "validate:html": "html-validate \".ci-site/xvsf/**/*.html\""
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "html-validate": "11.5.6",
    "yaml": "2.9.0"
  }
}
