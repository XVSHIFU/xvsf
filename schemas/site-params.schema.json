{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "xvsf editable site parameters",
  "type": "object",
  "required": ["author", "description", "keywords", "homeInfoParams", "announcement", "socialIcons", "footer"],
  "properties": {
    "author": { "type": "string", "minLength": 1 },
    "authorProfile": {
      "type": "object",
      "properties": {
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "avatarAlt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "description": { "type": "string", "minLength": 1 },
    "keywords": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "homeInfoParams": { "type": "object", "additionalProperties": true },
    "announcement": {
      "type": "object",
      "required": ["enabled", "text", "linkText", "url"],
      "properties": {
        "enabled": { "type": "boolean" },
        "text": { "type": "string" },
        "linkText": { "type": "string" },
        "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "socialIcons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "enabled", "weight"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "url": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "weight": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "footer": {
      "type": "object",
      "required": ["hideCopyright", "text", "startDate"],
      "properties": {
        "hideCopyright": { "type": "boolean" },
        "text": { "type": "string" },
        "startDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
